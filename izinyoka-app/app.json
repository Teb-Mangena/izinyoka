{
  "expo": {
    "name": "Izinyoka Tracker",
    "slug": "izinyoka-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/izinyoka-icon.png",
    "scheme": "izinyokatracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icons/izinyoka-icon.png",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photo library so you can choose images to upload",
        "NSCameraUsageDescription": "We need to access your camera so you can take images to upload"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/izinyoka-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "package": "com.tebmangena.izinyokatracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/izinyoka-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e888afa-99ac-4cc1-8fc6-7404a3f3dac6"
      }
    }
  }
}
